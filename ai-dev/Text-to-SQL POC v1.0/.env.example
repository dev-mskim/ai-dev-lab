# .env.example - 이 파일을 복사해서 .env 파일로 만드세요
# cp .env.example .env

# Claude API 키 (https://console.anthropic.com 에서 발급)
ANTHROPIC_API_KEY=sk-ant-여기에_발급받은_키_입력

# DB 설정 (데모용 SQLite - 변경 불필요)
DB_TYPE=sqlite
DB_PATH=data/sample.db

# Oracle 연동 시 아래 항목 설정 (데모 완성 후)
# DB_TYPE=oracle
# ORACLE_USER=your_username
# ORACLE_PASSWORD=your_password
# ORACLE_HOST=your_host
# ORACLE_PORT=1521
# ORACLE_SERVICE=your_service_name
